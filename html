<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Design Day</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>

    <!-- HEADER -->
    <header>
        <h1>🎨 Design Day</h1>
    </header>

    <!-- INFO SECTION -->
    <section class="info">
        <h2>About the Event</h2>
        <p>
            <b>Design Day</b> is a special school event where students explore creativity,
            technology, and innovation. Participants will discover graphic design,
            web design, and digital art.
        </p>
        <p>
            It is a great opportunity to <b>learn new skills</b>, showcase talents,
            and collaborate with others.
        </p>
    </section>

    <!-- SCHEDULE TABLE -->
    <section class="schedule">
        <h2>Event Schedule</h2>
        <table>
            <tr>
                <th>Time</th>
                <th>Activity</th>
            </tr>
            <tr>
                <td>09:00</td>
                <td>Opening Ceremony</td>
            </tr>
            <tr>
                <td>10:00</td>
                <td>Design Workshop</td>
            </tr>
            <tr>
                <td>11:30</td>
                <td>Creative Challenge</td>
            </tr>
            <tr>
                <td>13:00</td>
                <td>Closing & Awards</td>
            </tr>
        </table>
    </section>

    <!-- IMAGE -->
    <section class="image">
        <h2>Technology & Design</h2>
        <img src="https://via.placeholder.com/400" alt="Computer Image">
    </section>

    <!-- FORM -->
    <section class="form">
        <h2>Sign Up</h2>
        <form>
            <label>Name:</label><br>
            <input type="text" required><br><br>

            <label>Email:</label><br>
            <input type="email" required><br><br>

            <button type="submit">Register</button>
        </form>
    </section>

</body>
</html>
